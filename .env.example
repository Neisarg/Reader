# Get your API key from https://www.zotero.org/settings/keys
# Create a key with read/write access to your library
ZOTERO_API_KEY=

# Your Zotero user ID (visible at https://www.zotero.org/settings/keys)
ZOTERO_USER_ID=

# Claude API key for AI assistant (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=
